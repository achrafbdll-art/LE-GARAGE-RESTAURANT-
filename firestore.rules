rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isAdmin() {
      return isVerified() && request.auth.token.email == 'achrafbdll@gmail.com';
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // 1. Restorations
    match /restorations/{restorationId} {
      function isValidRestoration(data) {
        return data.keys().hasAll(['name', 'model', 'year', 'status', 'progress']) &&
               data.name is string && data.name.size() <= 100 &&
               data.model is string && data.model.size() <= 100 &&
               data.year is number && data.year >= 1886 && data.year <= 2100 &&
               data.status in ['Waiting', 'In Progress', 'Finished'] &&
               data.progress is number && data.progress >= 0 && data.progress <= 100 &&
               (data.get('image', '') is string) &&
               (data.get('tasks', []) is list) &&
               (data.get('updatedAt', request.time) is timestamp);
      }

      allow read: if true; // Public gallery
      
      allow create: if isAdmin() && isValidRestoration(incoming()) && isValidId(restorationId);
      
      allow update: if isAdmin() && isValidRestoration(incoming()) && (
        // Any change by admin is allowed if schema valid
        incoming().diff(existing()).affectedKeys().hasAny(['status', 'progress', 'tasks', 'image', 'updatedAt'])
      );
      
      allow delete: if isAdmin();
    }

    // 2. Menu Items & Categories
    match /menuItems/{itemId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // 3. Reservations
    match /reservations/{resId} {
      allow create: if (incoming().keys().hasAll(['customerName', 'email', 'date', 'guests']) &&
                      incoming().customerName is string && incoming().customerName.size() <= 100 &&
                      incoming().email is string && incoming().email.matches('^.+@.+$') &&
                      incoming().guests is number && incoming().guests > 0 && incoming().guests <= 50);
      allow read, update, delete: if isAdmin() || (isSignedIn() && existing().userId == request.auth.uid);
    }

    // 4. Event Inquiries
    match /eventInquiries/{inquiryId} {
      allow create: if true; // Public can inquire
      allow read, update, delete: if isAdmin();
    }
    
    // 5. User Profiles (PII Isolation)
    match /users/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    // 6. System checks
    match /system/{docId} {
      allow read: if true;
    }
  }
}
