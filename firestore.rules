rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() { return request.auth != null; }
    function isVerified() { return isSignedIn() && request.auth.token.email_verified == true; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // Category Rules
    match /categories/{categoryId} {
      allow read: if true; // Publicly readable
      allow write: if false; // System/Admin only - manual entry for now
    }

    // MenuItem Rules
    match /menuItems/{itemId} {
      allow read: if true;
      allow write: if false; // System/Admin only
    }

    // Reservation Rules
    function isValidReservation(data) {
      return data.keys().hasAll(['customerName', 'email', 'date', 'guests', 'status']) &&
             data.customerName is string && data.customerName.size() <= 100 &&
             data.email is string && data.email.size() <= 100 &&
             data.date is string &&
             data.guests is number && data.guests > 0 && data.guests <= 20 &&
             data.status in ['pending', 'confirmed', 'cancelled'];
    }

    match /reservations/{reservationId} {
      allow create: if isValidReservation(incoming()) && (incoming().status == 'pending');
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || resource.data.email == request.auth.token.email);
      allow update: if isSignedIn() && (resource.data.userId == request.auth.uid) && 
                      incoming().diff(existing()).affectedKeys().hasOnly(['status', 'specialRequests']) &&
                      incoming().status == 'cancelled';
    }

    // Event Inquiry Rules
    function isValidInquiry(data) {
       return data.keys().hasAll(['name', 'email', 'date', 'guests']) &&
              data.name is string && data.email is string;
    }

    match /eventInquiries/{inquiryId} {
      allow create: if isValidInquiry(incoming());
      allow read: if false; // Only admin via console
    }
  }
}
